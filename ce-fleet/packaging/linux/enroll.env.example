# enroll.env — read by ce-enroll.service (EnvironmentFile=-/etc/ce/enroll.env).
#
# Copy to /etc/ce/enroll.env and fill in per-site values. In production these come from the deploy
# tool's secret store (Ansible Vault no_log, Intune/SCCM machine-scoped vars) — NEVER committed.
# The bootstrap secret is a short-TTL, tag-scoped shared key (Tailscale-authkey analogue); the
# delegate burns a one-time nonce per enrollment so a leaked secret cannot be replayed forever.

# The LAN regional delegate that runs ce-fleet-enroll /enroll (a PRIVATE/LAN address — never public).
CE_FLEET_DELEGATE_URL=http://delegate.radiology.hospital.lan:8855

# The shared bootstrap secret this node presents at /enroll (per-site, from Vault).
CE_FLEET_BOOTSTRAP_SECRET=replace-me-from-vault

# Optional: a pre-minted single-node enroll cap token (overrides the shared secret if set).
# CE_ENROLL_TOKEN=

# Node data dir (matches the systemd units).
CE_DATA_DIR=/var/lib/ce
