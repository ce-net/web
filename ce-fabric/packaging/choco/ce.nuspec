<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>ce</id>
    <version>0.1.0</version>
    <title>CE</title>
    <authors>Leif Rydenfalk</authors>
    <projectUrl>https://github.com/ce-net/ce</projectUrl>
    <licenseUrl>https://github.com/ce-net/ce/blob/main/LICENSE</licenseUrl>
