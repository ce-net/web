    <description>Peer-to-peer compute mesh and economy. Donate compute to the network, earn credits, spend credits on compute. Like if Bitcoin ran Docker.</description>
    <summary>P2P compute marketplace on a PoW blockchain.</summary>
    <tags>p2p blockchain compute docker cli</tags>
    <releaseNotes>https://github.com/ce-net/ce/releases/tag/v0.1.0</releaseNotes>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
