{
  "name": "ce-react-native",
  "private": true,
  "version": "0.1.0",
  "description": "Expo (react-native-web) on CE — one React Native UI exported to a static web bundle and persisted to ce.db",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "build": "expo export --platform web --output-dir dist"
  },
  "dependencies": {
    "expo": "^51.0.0",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.4.0"
  }
}
