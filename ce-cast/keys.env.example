# Rheo multi-platform broadcast — stream keys
# Copy to keys.env and fill in. keys.env is gitignored; never commit real keys.
#
# For each platform: BASE url + KEY. Leave a KEY empty to skip that platform.
# The script builds "<BASE>/<KEY>" per active platform and fans out via ffmpeg tee.

# --- Twitch ---  dashboard.twitch.tv > Settings > Stream > Primary Stream key
# Optionally swap the host for your nearest ingest (see ingest.twitch.tv).
TWITCH_URL=rtmp://live.twitch.tv/app
TWITCH_KEY=

# --- YouTube Live ---  studio.youtube.com > Create > Go Live > Stream key
YT_URL=rtmp://a.rtmp.youtube.com/live2
YT_KEY=

# --- X / Twitter ---  media.x.com > Producer > + Source  (copy the RTMP URL + key it shows)
# X gives a full server URL; paste it as X_URL (no trailing slash) and the key as X_KEY.
X_URL=
X_KEY=

# --- Kick ---  kick.com/dashboard > Settings > Stream  (Stream URL is rtmps://...; key separate)
KICK_URL=
KICK_KEY=

# --- Optional encoding overrides (defaults are tuned for the i3 + 4x upload) ---
# RES=1280x720
# FPS=30
# VBITRATE=2800k
# MAXRATE=3200k
# ABITRATE=160k
# CAM_H=170          # webcam overlay height in px (width auto); set 0 with NO_CAM=1 to drop cam
