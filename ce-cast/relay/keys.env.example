# ce-net relay restreamer — platform keys live HERE (on the relay), not on the Mac.
# Copy to relay/keys.env on the Hetzner box and fill in. Same keys as the Mac's
# keys.env; keeping them on the relay means the Mac only needs the relay address.

# The Mac pushes to: rtmp://<relay>:<PORT>/<APP>/<INGEST_KEY>
INGEST_KEY=rheo
# PORT=1935
# APP=live
# HLS_DIR=/var/www/hls

TWITCH_URL=rtmp://live.twitch.tv/app
TWITCH_KEY=

YT_URL=rtmp://a.rtmp.youtube.com/live2
YT_KEY=

X_URL=
X_KEY=

KICK_URL=
KICK_KEY=
