[Unit]
Description=ce-cast relay agent (scene-graph -> ffmpeg compositor + zmq live control)
After=ce-cast-mediamtx.service network-online.target
Wants=ce-cast-mediamtx.service

[Service]
WorkingDirectory=/opt/ce-cast/relay
Environment=CAST_PREFIX=c0be11e0ce
Environment=RELAY_DIR=/opt/ce-cast/relay
ExecStart=/usr/bin/python3 /opt/ce-cast/relay/cast-agent.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
